# Supermemory Local endpoint
SUPERMEMORY_URL=http://localhost:6767
SUPERMEMORY_API_KEY=
CONTAINER_TAG=trace

# Comma-separated: filesystem,browser,editor,terminal,clipboard
WATCH_SOURCES=filesystem,editor,terminal,clipboard

# Semicolon-separated paths to watch
WATCH_PATHS=C:\Projects

# Chrome history
CHROME_HISTORY=%USERPROFILE%\AppData\Local\Google\Chrome\User Data\Default\History

# PowerShell history
SHELL_HISTORY=%USERPROFILE%\AppData\Roaming\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt

# Ports
API_PORT=6768
HUD_PORT=6769

# LLM for Q&A (optional)
LLM_URL=
LLM_MODEL=
LLM_API_KEY=

# Daily digest hour (local 0-23). A markdown summary is written to ~/.trace/digests/
DIGEST_HOUR=21

# Auto-update check (set to false to disable)
AUTO_UPDATE_CHECK=true
# When a newer version is found, also download the release asset to ./release
AUTO_UPDATE_DOWNLOAD=false
# JSON endpoint returning { version, url, notes } for update notifications
UPDATE_URL=
